# ============================================
# AreteIA - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Docker Project Name ---
COMPOSE_PROJECT_NAME=areteia

# --- Deployment Mode ---
# Choose ONE of the following COMPOSE_FILE options:
#
# Option A: All-in-one (Moodle + Python AI in a single Docker Compose stack)
#   Useful for local dev or self-contained installs.
#   Uses: docker-compose.yml
COMPOSE_FILE=docker-compose.yml
#
# Option B: Split stacks (Moodle and Python AI managed separately)
#   Useful when Moodle is already running or managed independently.
#   Uses: docker-compose.moodle.yml + docker-compose.python.yml
#   To use: uncomment the line below and comment out Option A
# COMPOSE_FILE=docker-compose.moodle.yml:docker-compose.python.yml
#
# Option C: VPS / bare-metal (Moodle installed natively, Python AI via Docker)
#   Moodle runs on the host; only the Python service uses Docker.
#   Deploy with: bash scripts/deploy-vps.sh [branch]
#   No COMPOSE_FILE needed — the deploy script handles everything.

# --- Proxy (leave empty if not needed) ---
HTTP_PROXY=
HTTPS_PROXY=

# --- Moodle Configuration ---
MOODLE_VERSION=MOODLE_405_STABLE
MOODLE_URL=http://localhost:8080
MOODLE_DATA_ROOT=/var/www/moodledata

# --- Database Configuration ---
DB_TYPE=pgsql
DB_HOST=db
DB_NAME=moodle
DB_USER=dbuser
DB_PASS=changeme
DB_PORT=5432

# --- Moodle Admin (first install only) ---
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=changeme
MOODLE_ADMIN_EMAIL=admin@example.com
MOODLE_FULLNAME=AreteIA Moodle
MOODLE_SHORTNAME=AreteIA

# --- AreteIA AI Service ---
ARETEIA_SYNC_PATH=/app/data/sync
ARETEIA_AI_URL=http://python_rag:8000

# --- LLM Provider ---
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# Optional. Leave empty for official OpenAI API.
OPENAI_BASE_URL=

# --- Embeddings / HuggingFace ---
# Required if the selected sentence-transformers model needs authentication.
HF_TOKEN=